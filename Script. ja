const audio = new Audio();
const playBtn = document.getElementById('play-pause');
const playIcon = document.getElementById('play-icon');
const progressBar = document.getElementById('progress-bar');
const disk = document.getElementById('disk');
const titleDisplay = document.getElementById('title');
const playlistElement = document.getElementById('playlist-list');

let isPlaying = false;
let currentSongIndex = parseInt(localStorage.getItem('lastSongIndex')) || 0;

// Lista de tus Beats (Aquí puedes poner los tuyos si ya los subiste)
const misBeats = [
    { title: "Demo Beat Jamnerd", file: "https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3" }
];

// SONIDOS PARA LOS PADS (Enlaces externos gratuitos)
const sounds = {
    'kick': 'https://actions.google.com/sounds/v1/percussion/bass_drum_hit.ogg',
    'snare': 'https://actions.google.com/sounds/v1/percussion/snare_drum_hit.ogg',
    'hat': 'https://actions.google.com/sounds/v1/percussion/hi_hat_hit.ogg',
    'fx': 'https://actions.google.com/sounds/v1/impacts/crash_cymbal.ogg',
    'guitar': 'https://cdn.pixabay.com/audio/2022/03/10/audio_c97693006d.mp3', // Melodía corta
    'piano-sad': 'https://cdn.pixabay.com/audio/2022/03/15/audio_22822a106d.mp3',
    'synth': 'https://cdn.pixabay.com/audio/2022/01/21/audio_1456a00c6d.mp3',
    'reggaeton': 'https://actions.google.com/sounds/v1/transportation/car_horn.ogg' // Efecto DJ
};

function loadPlaylist() {
    playlistElement.innerHTML = "";
    misBeats.forEach((beat, index) => {
        const li = document.createElement('li');
        li.className = `song-item ${index === currentSongIndex ? 'active' : ''}`;
        li.innerText = beat.title;
        li.onclick = () => selectSong(index);
        playlistElement.appendChild(li);
    });
}

function selectSong(index) {
    currentSongIndex = index;
    audio.src = misBeats[currentSongIndex].file;
    titleDisplay.innerText = misBeats[currentSongIndex].title;
    localStorage.setItem('lastSongIndex', index);
    loadPlaylist();
    if(isPlaying) audio.play();
}

// FUNCIÓN PARA REPRODUCIR LOS PADS
window.playAudio = function(id) {
    const s = new Audio(sounds[id]);
    s.play().catch(e => console.log("Error al cargar sonido"));
    
    // Efecto visual rápido
    const pad = document.querySelector(`.${id}`);
    if(pad) {
        pad.style.filter = "brightness(2)";
        setTimeout(() => pad.style.filter = "brightness(1)", 100);
    }
}

playBtn.addEventListener('click', () => {
    if (isPlaying) {
        audio.pause();
        playIcon.innerText = 'play_arrow';
        disk.style.animationPlayState = 'paused';
    } else {
        if(!audio.src) selectSong(currentSongIndex);
        audio.play();
        playIcon.innerText = 'pause';
        disk.style.animationPlayState = 'running';
    }
    isPlaying = !isPlaying;
});

audio.addEventListener('timeupdate', () => {
    progressBar.style.width = (audio.currentTime / audio.duration) * 100 + '%';
});

loadPlaylist();
selectSong(currentSongIndex);
