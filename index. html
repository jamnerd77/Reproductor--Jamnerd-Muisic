<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Jamnerd Studio Pro</title>
    <link rel="stylesheet" href="style.css">
    <link rel="manifest" href="manifest.json">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
</head>
<body>
    <div class="player-container">
        <div class="header"><span>JAMNERD STUDIO PRO</span></div>
        
        <div class="art-container"><div class="disk" id="disk"><i class="material-icons">album</i></div></div>
        <div class="song-info"><h1 id="title">Cargando...</h1><p>Jamnerd Production</p></div>
        <div class="progress-container"><div class="progress-bar" id="progress-bar"></div></div>
        
        <div class="controls">
            <button id="prev"><i class="material-icons">skip_previous</i></button>
            <button id="play-pause" class="play-btn"><i class="material-icons" id="play-icon">play_arrow</i></button>
            <button id="next"><i class="material-icons">skip_next</i></button>
        </div>

        <div class="section-title">DRUM PADS</div>
        <div class="dj-pads drums">
            <div class="pad kick" onclick="playAudio('kick')">KICK</div>
            <div class="pad snare" onclick="playAudio('snare')">SNARE</div>
            <div class="pad hat" onclick="playAudio('hat')">HAT</div>
            <div class="pad fx" onclick="playAudio('fx')">FX</div>
        </div>

        <div class="section-title">MELODY LOOPS</div>
        <div class="dj-pads melodies">
            <div class="pad guitar" onclick="playAudio('guitar')">GUITAR</div>
            <div class="pad piano-sad" onclick="playAudio('piano-sad')">SAD PIANO</div>
            <div class="pad synth" onclick="playAudio('synth')">SYNTH</div>
            <div class="pad reggaeton" onclick="playAudio('reggaeton')">PIANO REG.</div>
        </div>

        <div class="extra-actions">
            <button id="voice-search" class="action-btn"><i class="material-icons">mic</i></button>
            <button id="share-whatsapp" class="action-btn"><i class="material-icons">share</i></button>
        </div>
        
        <div id="status-msg"></div>
        <div class="playlist"><h2>Mis Beats</h2><ul id="playlist-list"></ul></div>
    </div>
    
    <audio id="sound-kick" src="kick.mp3"></audio>
    <audio id="sound-snare" src="snare.mp3"></audio>
    <audio id="sound-hat" src="hat.mp3"></audio>
    <audio id="sound-fx" src="fx.mp3"></audio>
    <audio id="sound-guitar" src="guitar.mp3"></audio>
    <audio id="sound-piano-sad" src="piano_sad.mp3"></audio>
    <audio id="sound-synth" src="synth.mp3"></audio>
    <audio id="sound-reggaeton" src="piano_reggaeton.mp3"></audio>

    <script src="script.js"></script>
</body>
</html>
