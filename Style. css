body { background: #0a0a0a; color: white; font-family: 'Segoe UI', sans-serif; display: flex; justify-content: center; align-items: center; min-height: 100vh; margin: 0; padding: 20px 0; }
.player-container { background: #141414; width: 92%; max-width: 360px; padding: 20px; border-radius: 25px; text-align: center; box-shadow: 0 15px 40px rgba(0,0,0,0.7); border: 1px solid #333; }
.header { font-size: 10px; color: #666; letter-spacing: 3px; margin-bottom: 15px; }
.disk { width: 140px; height: 140px; background: linear-gradient(45deg, #6200ee, #03dac6); border-radius: 50%; margin: 0 auto; display: flex; justify-content: center; align-items: center; animation: rotate 6s linear infinite; animation-play-state: paused; }
@keyframes rotate { from { transform: rotate(0); } to { transform: rotate(360deg); } }
.song-info h1 { font-size: 18px; margin: 10px 0; }
.progress-container { background: #222; height: 4px; border-radius: 10px; margin: 15px 0; }
.progress-bar { background: #03dac6; height: 100%; width: 0%; transition: width 0.1s; }
.controls { display: flex; justify-content: space-around; align-items: center; margin-bottom: 20px; }
.play-btn { background: white; color: black; width: 50px; height: 50px; border-radius: 50%; display: flex; justify-content: center; align-items: center; }

.section-title { font-size: 10px; color: #03dac6; text-align: left; margin: 15px 0 5px 5px; font-weight: bold; }
.dj-pads { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin-bottom: 10px; }
.pad { padding: 12px 0; border-radius: 8px; font-size: 9px; font-weight: bold; cursor: pointer; text-align: center; border-bottom: 3px solid rgba(0,0,0,0.3); }
.pad:active { transform: translateY(2px); border-bottom: 0; }

/* Colores de los Pads */
.kick { background: #e91e63; } .snare { background: #9c27b0; } .hat { background: #2196f3; } .fx { background: #ff9800; }
.guitar { background: #4caf50; } .piano-sad { background: #3f51b5; } .synth { background: #00bcd4; } .reggaeton { background: #f44336; }

.extra-actions { display: flex; justify-content: center; gap: 20px; margin: 15px 0; }
.action-btn { background: #222; color: white; border: none; width: 40px; height: 40px; border-radius: 50%; }
.playlist { background: #1a1a1a; margin-top: 15px; border-radius: 15px; padding: 10px; max-height: 100px; overflow-y: auto; text-align: left; }
.song-item { padding: 8px; font-size: 12px; border-bottom: 1px solid #222; }
.song-item.active { color: #03dac6; font-weight: bold; }
